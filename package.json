{
  "name": "seat-reservation-api",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --minify",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "d1:apply:local": "wrangler d1 migrations apply webmcp --local",
    "d1:apply:remote": "wrangler d1 migrations apply webmcp --remote"
  },
  "dependencies": {
    "hono": "^4.12.28"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.18.4",
    "@cloudflare/workers-types": "^5.20260712.1",
    "typescript": "^5.9.2",
    "vitest": "^4.1.0",
    "wrangler": "^4.4.0"
  }
}
